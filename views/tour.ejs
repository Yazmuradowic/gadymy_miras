<%- include('partials/header'); -%>
<div class="tour-detail-page">
    <div class="container">
        <nav class="tour-breadcrumb">
            <a href="/">Home</a>
            <span>›</span>
            <a href="/tours">Tours</a>
            <span>›</span>
            <span><%= tur.tour_title %></span>
        </nav>

        <div class="tour-detail-card">
            <% const bannerImg = (typeof tur !== 'undefined' && tur.tour_picture) ? tur.tour_picture : 'https://tmtourism.com/uploads/tours/45/sT8GFa2PRPhE2TodxmFioJRHaFMD72mbcpwSjBHZ.webp'; %>
            <div class="tour-banner" style="background-image: url('<%= bannerImg %>');" role="img" aria-label="Tour cover"></div>
            <div class="card-body">
                <h1 class="card-title"><%= tur.tour_title %></h1>
                <div class="short_description">
                    <p><strong>Route:</strong> <%= tur.tour_start %></p>
                    <p><%= tur.tour_text %></p>
                </div>
                <div class="tour-stats-row">
                    <div class="tour-stat-box">
                        <i class="fas fa-calendar-alt"></i>
                        <div class="stat-value"><%= tur.day %></div>
                        <div class="stat-label">days</div>
                    </div>
                    <div class="tour-stat-box">
                        <i class="fas fa-users"></i>
                        <div class="stat-value">0</div>
                        <div class="stat-label">groups</div>
                    </div>
                    <div class="tour-stat-box">
                        <i class="fas fa-bed"></i>
                        <div class="stat-value">0</div>
                        <div class="stat-label">options</div>
                    </div>
                </div>

                <h5 class="tour-program-title">What is included / not included</h5>

                <div class="accordion tour-accordion" id="accordionInclusions">
                    <div class="card">
                        <div class="card-header p-0" id="headingInclusions">
                            <h5 class="mb-0">
                                <button class="btn btn-link" type="button" data-toggle="collapse" data-target="#collapseInclusions" aria-expanded="true" aria-controls="collapseInclusions">
                                    <h4 class="mb-0">What's included? <i class="fas fa-chevron-down ml-2 chevron-icon"></i></h4>
                                </button>
                            </h5>
                        </div>
                        <div id="collapseInclusions" class="collapse show" aria-labelledby="headingInclusions" data-parent="#accordionInclusions">
                            <div class="card-body">
                                <ul>
                                    <li>Visa support (Letter of Invitation, State Registration, Travel Pass)</li>
                                    <li>Road transport in private air-conditioned vehicles, regular.</li>
                                    <li>Accommodation based on 3*Mizan otel or similar.</li>
                                    <li>Meal: F/B</li>
                                    <li>Tourist entrance tax at every hotel 2 $</li>
                                    <li>English-speaking guide-interpreter services.</li>
                                    <li>Entrance fees to sites mentioned in the program, as per price differentiation</li>
                                    <li>Bottled water 1,5 ltr per person.</li>
                                    <li>Porter services</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="card">
                        <div class="card-header p-0" id="headingExclusions">
                            <h5 class="mb-0">
                                <button class="btn btn-link collapsed" type="button" data-toggle="collapse" data-target="#collapseExclusions" aria-expanded="false" aria-controls="collapseExclusions">
                                    <h4 class="mb-0">What's not included? <i class="fas fa-chevron-down ml-2 chevron-icon"></i></h4>
                                </button>
                            </h5>
                        </div>
                        <div id="collapseExclusions" class="collapse" aria-labelledby="headingExclusions" data-parent="#accordionInclusions">
                            <div class="card-body">
                                <ul>
                                    <li>Turkmenistan tourist visa from 55 to 100 USD per person (depending on the country of residence), in the endurance to the Country (subject to change)</li>
                                    <li>Turkmenistan migration tax 12 USD per person, to be paid at entering borders (subject to change)</li>
                                    <li>Photo/video fees at historical sites and museums</li>
                                    <li>Tips for local guide(s) and/or driver(s)</li>
                                    <li>Souvenirs and other personal items</li>
                                    <li>All other charges and services not mentioned under “Included”</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <h5 class="tour-program-title">Tour program</h5>
                <div class="accordion tour-accordion" id="itineraryAccordion">
  <% for (let i = 0; i < days.length; i++) { %>

    <div class="card">
      <div class="card-header p-0" id="headingDay<%= i %>">
        <button class="btn btn-link collapsed" type="button"
          data-toggle="collapse"
          data-target="#collapseDay<%= i %>">

          <h4 class="mb-0">
            <%= days[i].day_title %>
            <i class="fas fa-chevron-down ml-2"></i>
          </h4>

        </button>
      </div>

      <div id="collapseDay<%= i %>" class="collapse" data-parent="#itineraryAccordion">
        <div class="card-body">
          <%= days[i].text %>
        </div>
      </div>

    </div>

  <% } %>
</div>


                <div class="tour-tags">
                    <span class="tour-tag"><i class="fas fa-map-marker-alt"></i> From Shavat / Khiva</span>
                    <span class="tour-tag">Darvaza Gas Crater</span>
                    <span class="tour-tag">Short Breaks (1–3 days)</span>
                </div>
            </div>
        </div>
    </div>
</div>
<%- include('partials/footer'); -%>
