<%- include('partials/header'); -%>
    <!-- GALLERY SECTION -->
    <section id="gallery" class="gallery-section">
        <div class="container">
            <h2 class="section-title">Videos</h2>
            <div class="gallery-grid">
                <div class="video-gallery">
                    <% if (videos && videos.length) { %>
                        <% videos.forEach(function(video) { %>
                            <div class="video-item" onclick="playVideo(this)">
                                <div class="video-wrapper">
                                    <img src="<%= video.poster_url %>" alt="<%= video.title || 'Video' %>" class="poster">
                                    <video controls data-src="<%= video.video_url %>"></video>
                                    <div class="play-button"></div>
                                </div>
                                <div class="video-caption"><%= video.title || 'Video' %></div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p style="padding: 1rem 0; text-align:center;">Wideolar entek goşulmady.</p>
                    <% } %>
                </div>
    </section>
    <%- include('partials/footer'); -%>