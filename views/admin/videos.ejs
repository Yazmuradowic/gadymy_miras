<%- include('adminpartials/header'); -%>
    <main class="admin-content">
        <section class="admin-section">
            <div class="admin-section-header">
                <h2>Täze wideo goşmak</h2>
            </div>

            <% if (error) { %>
                <div class="login-error" style="margin-bottom: 1rem;">
                    <i class="fas fa-exclamation-circle"></i>
                    <%= error %>
                </div>
                <% } %>

                    <form id="adminVideoUploadForm" action="/gadymymiras/admin/videos" method="post" class="login-form"
                        enctype="multipart/form-data" novalidate>
                        <div class="form-group">
                            <label for="title"><i class="fas fa-tag"></i> Ady</label>
                            <input type="text" id="title" name="title" placeholder="Mysal: Darwaza wideosy" required>
                        </div>
                        <div class="form-group">
                            <label for="poster_file"><i class="fas fa-image"></i> Poster suraty (faýl)</label>
                            <input type="file" id="poster_file" name="poster_file" accept="image/*" required>
                        </div>
                        <div class="form-group">
                            <label for="video_file"><i class="fas fa-film"></i> Wideo faýly</label>
                            <input type="file" id="video_file" name="video_file" accept="video/*" required>
                        </div>
                        <button id="adminVideoUploadSubmit" type="submit" class="btn-login">Goş</button>

                        <div id="adminVideoUploadProgress" class="upload-progress" style="display:none;">
                            <div class="upload-progress__top">
                                <div class="upload-progress__label">Ýüklenýär...</div>
                                <div id="adminVideoUploadPercent" class="upload-progress__percent">0%</div>
                            </div>
                            <div class="upload-progress__bar">
                                <div id="adminVideoUploadBar" class="upload-progress__bar-fill" style="width:0%;"></div>
                            </div>
                            <div id="adminVideoUploadError" class="upload-progress__error" style="display:none;"></div>
                        </div>
                    </form>
        </section>

        <section class="admin-section" style="margin-top: 1.5rem;">
            <div class="admin-section-header">
                <h2>Bar bolan wideolar</h2>
            </div>

            <% if (videos && videos.length) { %>
                <div class="gallery-grid">
                    <% videos.forEach(function(video) { %>
                        <div class="gallery-item" style="position: relative;">
                            <div class="video-item">
                                <div class="video-wrapper">
                                    <img src="<%= video.poster_url %>" alt="<%= video.title || 'Video' %>"
                                        class="poster">
                                    <video controls data-src="<%= video.video_url %>"></video>
                                    <div class="play-button"></div>
                                </div>
                                <div class="video-caption">
                                    <%= video.title || 'Video' %>
                                </div>
                            </div>
                            <div
                                style="position:absolute; inset:0; background:linear-gradient(to top, rgba(15,23,42,0.9), transparent 60%); display:flex; flex-direction:column; justify-content:flex-end; padding:0.75rem; gap:0.35rem;">
                                <form action="/gadymymiras/admin/videos/<%= video.id %>/update" method="post"
                                    enctype="multipart/form-data"
                                    style="display:flex; flex-direction:column; gap:0.35rem; background:rgba(15,23,42,0.7); padding:0.4rem; border-radius:8px;">
                                    <p>Wideo Ady</p>
                                    <input type="text" name="title" value="<%= video.title || '' %>" placeholder="Ady"
                                        style="padding:0.2rem 0.4rem; border-radius:6px; border:none; font-size:0.8rem;">
                                    <p>Wideo Surat</p>
                                    <input type="file" name="poster_file" accept="image/*"
                                        style="padding:0.15rem 0.4rem; border-radius:6px; border:none; font-size:0.78rem; background:rgba(15,23,42,0.9); color:#e5e7eb;">
                                    <p>Wideo Faýly</p>
                                    <input type="file" name="video_file" accept="video/*"
                                        style="padding:0.15rem 0.4rem; border-radius:6px; border:none; font-size:0.78rem; background:rgba(15,23,42,0.9); color:#e5e7eb;">
                                    <button type="submit"
                                        style="padding:0.25rem 0.4rem; border-radius:999px; border:none; font-size:0.75rem; font-weight:600; cursor:pointer; background:#38bdf8; color:#0f172a;">Üýtget</button>
                                </form>
                                <form action="/gadymymiras/admin/videos/<%= video.id %>/delete" method="post">
                                    <button type="submit"
                                        style="margin-top:0.25rem; padding:0.2rem 0.4rem; border-radius:999px; border:1px solid rgba(248,113,113,0.8); font-size:0.75rem; font-weight:600; cursor:pointer; background:rgba(127,29,29,0.9); color:#fecaca;">
                                        Poz
                                    </button>
                                </form>
                            </div>
                        </div>
                        <% }) %>
                </div>
                <% } else { %>
                    <p style="padding: 0.5rem 0; text-align:center; color:#e5e7eb;">Entäk hiç hili wideo goşulmady.</p>
                    <% } %>
        </section>
    </main>

    <script>
        (function () {
            const form = document.getElementById('adminVideoUploadForm');
            if (!form) return;

            const submitBtn = document.getElementById('adminVideoUploadSubmit');
            const progressWrap = document.getElementById('adminVideoUploadProgress');
            const percentEl = document.getElementById('adminVideoUploadPercent');
            const barEl = document.getElementById('adminVideoUploadBar');
            const errorEl = document.getElementById('adminVideoUploadError');

            const showError = (msg) => {
                if (!errorEl) return;
                errorEl.textContent = msg || 'Ýalňyşlyk boldy';
                errorEl.style.display = 'block';
            };
            const clearError = () => {
                if (!errorEl) return;
                errorEl.textContent = '';
                errorEl.style.display = 'none';
            };
            const setProgress = (pct) => {
                const clamped = Math.max(0, Math.min(100, pct || 0));
                if (percentEl) percentEl.textContent = clamped + '%';
                if (barEl) barEl.style.width = clamped + '%';
            };

            form.addEventListener('submit', function (e) {
                e.preventDefault();
                clearError();

                const fd = new FormData(form);
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span class="loader"></span>Ýüklenýär...';
                }
                if (progressWrap) progressWrap.style.display = 'block';
                setProgress(0);

                const xhr = new XMLHttpRequest();
                xhr.open('POST', form.action, true);
                xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
                xhr.setRequestHeader('Accept', 'application/json');

                xhr.upload.onprogress = function (evt) {
                    if (!evt || !evt.lengthComputable) return;
                    const pct = Math.round((evt.loaded / evt.total) * 100);
                    setProgress(pct);
                };

                xhr.onerror = function () {
                    showError('Baglanyşyk ýalňyşlygy. Täzeden synanyşyň.');
                };

                xhr.onload = function () {
                    const ct = (xhr.getResponseHeader('content-type') || '').toLowerCase();
                    if (!ct.includes('application/json')) {
                        if (xhr.status >= 200 && xhr.status < 400) {
                            window.location.href = '/gadymymiras/admin/videos';
                            return;
                        }
                        showError('Serwer jogaby näbelli boldy.');
                        return;
                    }

                    let data = null;
                    try { data = JSON.parse(xhr.responseText || '{}'); } catch (_) { data = null; }

                    if (xhr.status >= 200 && xhr.status < 300 && data && data.ok) {
                        window.location.href = data.redirect || '/gadymymiras/admin/videos';
                        return;
                    }

                    showError((data && data.error) ? data.error : 'Wideo ýüklenmedi.');
                };

                xhr.onloadend = function () {
                    if (submitBtn) {
                        submitBtn.disabled = false;
                        submitBtn.textContent = 'Goş';
                    }
                };

                xhr.send(fd);
            });
        })();
    </script>

    <%- include('adminpartials/footer'); -%>