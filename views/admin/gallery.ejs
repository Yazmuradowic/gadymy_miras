<%- include('adminpartials/header'); -%>
    <main class="admin-content">
        <section class="admin-section">
            <div class="admin-section-header">
                <h2>Täze surat goşmak</h2>
            </div>

            <% if (error) { %>
                <div class="login-error" style="margin-bottom: 1rem;">
                    <i class="fas fa-exclamation-circle"></i>
                    <%= error %>
                </div>
                <% } %>

                    <form action="/gadymymiras/admin/gallery" method="post" class="login-form"
                        enctype="multipart/form-data">
                        <div class="form-group">
                            <label for="image_file"><i class="fas fa-image"></i> Surat faýly</label>
                            <input type="file" id="image_file" name="image_file" accept="image/*">
                        </div>
                        <div class="form-group">
                            <label for="image_url"><i class="fas fa-link"></i> Ýa-da URL adresi (islege görä)</label>
                            <input type="text" id="image_url" name="image_url"
                                placeholder="Mysal: /image/galery/1.jpg ýa-da https://...">
                        </div>
                        <button type="submit" class="btn-login">Goş</button>
                    </form>
        </section>

        <section class="admin-section" style="margin-top: 1.5rem;">
            <div class="admin-section-header">
                <h2>Bar bolan suratlar</h2>
            </div>

            <% if (photos && photos.length) { %>
                <div class="gallery-grid">
                    <% photos.forEach(function(photo) { %>
                        <div class="gallery-item" style="position: relative;">
                            <img src="<%= photo.gallery_url %>" alt="Gallery photo">
                            <div
                                style="position:absolute; inset:0; background:linear-gradient(to top, rgba(15,23,42,0.9), transparent 60%); display:flex; flex-direction:column; justify-content:flex-end; padding:0.75rem; gap:0.35rem;">
                                <form action="/gadymymiras/admin/gallery/<%= photo.id %>/update" method="post"
                                    enctype="multipart/form-data"
                                    style="display:flex; flex-direction:column; gap:0.35rem;">
                                    <input type="file" name="image_file" accept="image/*"
                                        style="padding:0.15rem 0.4rem; border-radius:6px; border:none; font-size:0.78rem; background:rgba(15,23,42,0.9); color:#e5e7eb;">
                                    <input type="text" name="image_url" value="<%= photo.gallery_url %>"
                                        placeholder="URL (islege görä)"
                                        style="padding:0.25rem 0.4rem; border-radius:6px; border:none; font-size:0.8rem;">
                                    <button type="submit"
                                        style="padding:0.25rem 0.4rem; border-radius:999px; border:none; font-size:0.75rem; font-weight:600; cursor:pointer; background:#38bdf8; color:#0f172a;">Üýtget</button>
                                </form>
                                <form action="/gadymymiras/admin/gallery/<%= photo.id %>/delete" method="post">
                                    <button type="submit"
                                        style="margin-top:0.25rem; padding:0.2rem 0.4rem; border-radius:999px; border:1px solid rgba(248,113,113,0.8); font-size:0.75rem; font-weight:600; cursor:pointer; background:rgba(127,29,29,0.9); color:#fecaca;">
                                        Poz
                                    </button>
                                </form>
                            </div>
                        </div>
                        <% }) %>
                </div>
                <% } else { %>
                    <p style="padding: 0.5rem 0; text-align:center; color:#e5e7eb;">Galereýada entek surat ýok.</p>
                    <% } %>
        </section>
    </main>
    <%- include('adminpartials/footer'); -%>